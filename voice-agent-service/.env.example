# Local dev: copy to .env.local and fill in as needed (tsx/dotenv picks it up).
# Production (Oracle Cloud VM): copy to .env on the VM, chmod 600, never commit
# it -- docker-compose.yml loads it both for the voice-agent container's env
# vars and (VOICE_AGENT_DOMAIN only) for Caddy's automatic-HTTPS domain.

PORT=8080

# The public hostname Caddy requests a Let's Encrypt certificate for and
# proxies to the voice-agent container. Must already have a DNS A record
# pointing at this VM's public IP before `docker compose up` is run, or
# Caddy's ACME challenge will fail.
VOICE_AGENT_DOMAIN=voice-agent.telecomcompliance.uk

# Phase C onward -- all required, config.ts fails fast on boot if missing
# (except DATABASE_URL, which Prisma itself reads directly).
DATABASE_URL=postgresql://user:password@host:5432/postgres?sslmode=require
TWILIO_ACCOUNT_SID=ACreplace-with-real-account-sid
ANTHROPIC_API_KEY=sk-ant-replace-with-real-key
APP_URL=https://telecomcompliance.uk
