# Local dev: copy to .env.local and fill in as needed (tsx/dotenv picks it up).
# Production (Railway): set via the service's Variables tab in the Railway
# dashboard, or `railway variable set KEY --stdin --service heimdell-voice-agent`.
# Never commit a .env file with real values.

PORT=8080

# Phase C onward -- all required, config.ts fails fast on boot if missing
# (except DATABASE_URL, which Prisma itself reads directly).
DATABASE_URL=postgresql://user:password@host:5432/postgres?sslmode=require
TWILIO_ACCOUNT_SID=ACreplace-with-real-account-sid
ANTHROPIC_API_KEY=sk-ant-replace-with-real-key
APP_URL=https://telecomcompliance.uk
