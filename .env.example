# Heimdell Verified Consent API — Environment Variables
# -------------------------------------------------------
# This file is a SAFE TEMPLATE only. It must never contain real secrets.
# Copy this file to .env.local and fill in real values before running the app.
# .env.local is git-ignored and must never be committed.

# -------------------------------------------------------
# DATABASE_URL
# PostgreSQL connection string for Prisma.
# Update host, port, username, password, and database name to match your setup.
# For local development: postgresql://user:password@localhost:5432/heimdell_consent?schema=public
# For production: use a managed PostgreSQL service (e.g. Supabase, Neon, RDS).
# Serverless production should use a pooled connection URL with a conservative Prisma
# connection limit, for example: ?sslmode=require&connection_limit=1
# -------------------------------------------------------
DATABASE_URL="postgresql://user:password@localhost:5432/heimdell_consent?schema=public"

# -------------------------------------------------------
# DIRECT_URL
# A second, non-pooled (or session-mode-pooled) connection string used only
# by Prisma Migrate commands (migrate dev/status/deploy). Transaction-mode
# poolers (e.g. Supabase's port-6543 pooler used above for DATABASE_URL)
# don't support the session-level locks migrations need and will hang.
# If your database isn't behind a transaction pooler, this can be the same
# value as DATABASE_URL.
# -------------------------------------------------------
DIRECT_URL="postgresql://user:password@localhost:5432/heimdell_consent?schema=public"

# -------------------------------------------------------
# APP_URL
# The public base URL of this application.
# Used to construct verification links sent to customers, Supabase callback URLs,
# production metadata, and allowed embed frame origins.
# Production domain: https://telecomcompliance.uk
# Must NOT have a trailing slash.
# -------------------------------------------------------
APP_URL="http://localhost:3000"

# -------------------------------------------------------
# ENCRYPTION_KEY
# A 32-byte (256-bit) cryptographic key, base64-encoded.
# Used for AES-256-GCM encryption of sensitive data at rest (e.g. bank account numbers).
# MUST be replaced with a real generated key before production.
# Generate one by running: npm run generate:encryption-key
# -------------------------------------------------------
ENCRYPTION_KEY="replace-with-32-byte-base64-key"

# -------------------------------------------------------
# Supabase Auth
# Public project URL and anon key used for server-side dashboard auth.
# The anon key is safe to use with Supabase Auth, but still keep real values
# in environment variables. NEVER expose or use the service-role key in browser code.
# -------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL="https://your-project-ref.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="replace-with-supabase-anon-key"

# Server-only Supabase service-role key used by platform admins to provision
# client company users from /dashboard/clients/new. Never expose this in
# browser code and never prefix it with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY="replace-with-supabase-service-role-key"

# -------------------------------------------------------
# CRM embed tokens
# Server-only HMAC secret for short-lived CRM iframe tokens.
# Must be at least 32 characters. Never expose this in browser code.
# -------------------------------------------------------
EMBED_TOKEN_SECRET="replace-with-at-least-32-random-characters"

# -------------------------------------------------------
# CRM embed browser origins
# Comma or space separated origins that may frame /embed/* and call protected
# embed status endpoints from the browser. Use HTTPS origins in production.
# Do not include paths, raw API keys, or embed tokens.
# -------------------------------------------------------
ALLOWED_EMBED_ORIGINS="https://crm.example.com,https://app.hubspot.com"

# -------------------------------------------------------
# Rate limiting
# Local development can use the in-memory fallback. Production multi-instance
# deployments should use Upstash Redis REST or another Redis-compatible shared
# store wired through these variables. Never expose Redis tokens in browser code.
# RATE_LIMIT_STORE: "memory" | "upstash"
# RATE_LIMIT_FAIL_OPEN: "false" blocks requests if the shared limiter is down.
# -------------------------------------------------------
RATE_LIMIT_STORE="memory"
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""
RATE_LIMIT_FAIL_OPEN="false"

# -------------------------------------------------------
# Dashboard setup script inputs
# Used by: npm run setup:dashboard-user
# These map a Supabase Auth user to internal organization membership.
# Do not put secrets, raw API keys, or customer/payment data here.
# -------------------------------------------------------
DASHBOARD_ORG_NAME="Example Organization"
DASHBOARD_ORG_SLUG="example-organization"
DASHBOARD_USER_EMAIL="admin@example.com"
DASHBOARD_USER_EXTERNAL_AUTH_ID="supabase-auth-user-id"
DASHBOARD_USER_ROLE="OWNER"
# Optional client link helpers for local development only:
# DASHBOARD_LINK_CLIENT_ID="client_id_here"
# DASHBOARD_LINK_CLIENT_NAME="Example Client"
# DASHBOARD_LINK_DEV_CLIENT="false"

# -------------------------------------------------------
# Demo runbook setup inputs
# Used by: npm run setup:demo
# These create fake local demo organization/client/API-key records and can map
# a Supabase Auth user to the demo organization for dashboard access.
# Use fake local values only. Never use real customer data or production keys.
# -------------------------------------------------------
DEMO_API_KEY="use-a-fake-local-demo-key-of-at-least-24-characters"
DEMO_ORG_NAME="Heimdell Demo Organization"
DEMO_ORG_SLUG="heimdell-demo"
DEMO_CLIENT_NAME="Heimdell Demo Client"
DEMO_DASHBOARD_EMAIL="demo-admin@example.com"
DEMO_DASHBOARD_EXTERNAL_AUTH_ID="supabase-auth-user-id"
DEMO_WEBHOOK_URL="http://localhost:4010/webhook"
DEMO_SKIP_DASHBOARD_USER="false"

# -------------------------------------------------------
# Stripe (credit billing)
# STRIPE_SECRET_KEY: server-only Stripe secret key. Never expose in browser code.
# STRIPE_WEBHOOK_SECRET: signing secret for the /api/v1/webhooks/stripe endpoint,
# from the Stripe Dashboard (or `stripe listen` output in local development).
# -------------------------------------------------------
STRIPE_SECRET_KEY="sk_test_replace-with-real-key"
STRIPE_WEBHOOK_SECRET="whsec_replace-with-real-secret"

# -------------------------------------------------------
# Credit pricing
# Flat credit cost per verification. Both optional — sane defaults apply
# if unset (1 credit for a link, 5 for a phone call).
# -------------------------------------------------------
CREDIT_COST_LINK="1"
CREDIT_COST_PHONE_CALL="5"

# -------------------------------------------------------
# Twilio (SMS, WhatsApp, and Voice phone-call verification)
# TWILIO_ACCOUNT_SID / TWILIO_AUTH_TOKEN: from the Twilio Console.
# TWILIO_AUTH_TOKEN also signs/verifies every inbound Twilio webhook
# (src/lib/twilio-signature.ts) -- never expose it in browser code.
# TWILIO_SMS_FROM / TWILIO_WHATSAPP_FROM: sending numbers for text messages.
# TWILIO_VOICE_FROM: sending number for phone-call verification. Must be a
# Voice-capable Twilio number. Falls back to TWILIO_SMS_FROM if unset.
# -------------------------------------------------------
TWILIO_ACCOUNT_SID="ACreplace-with-real-account-sid"
TWILIO_AUTH_TOKEN="replace-with-real-auth-token"
TWILIO_SMS_FROM="+10000000000"
TWILIO_WHATSAPP_FROM="+10000000000"
TWILIO_VOICE_FROM="+10000000000"

# VOICE_AGENT_ENABLED / VOICE_AGENT_WS_URL: conversational AI phone agent
# cutover (see voice-agent-service/). Both must be set for a call to use the
# new agent -- leave unset (or VOICE_AGENT_ENABLED unset/"false") to keep
# using the existing disclosure + DTMF script, which is the default and the
# permanent rollback path.
# VOICE_AGENT_ENABLED="true"
# VOICE_AGENT_WS_URL="wss://voice-agent.telecomcompliance.uk"
